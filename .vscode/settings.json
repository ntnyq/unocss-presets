{
  "oxc.enable": true,
  "eslint.enable": false,
  "prettier.enable": false,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "cSpell.useGitignore": true,
  "cSpell.allowCompoundWords": true,
  "cSpell.words": [
    "attributify",
    "bezier",
    "bumpp",
    "changelogithub",
    "crema",
    "easings",
    "esbuild",
    "ginza",
    "hefe",
    "iconify",
    "kekab",
    "lcov",
    "lofi",
    "nocheck",
    "oxfmt",
    "oxlint",
    "perpetua",
    "pnpm",
    "stinson",
    "sutro",
    "tabler",
    "tada",
    "tsdown",
    "unplugin",
    "unrs",
    "vite",
    "vitejs",
    "vitest",
    "vueuse",
    "xingtong",
    "xpro"
  ]
}
